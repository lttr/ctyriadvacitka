{
  "name": "ctyriadvacitka",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "start": "node .output/server/index.mjs",
    "preview": "nuxt preview",
    "test": "vitest run",
    "typecheck": "nuxi typecheck",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --list-different --write .",
    "verify": "npm run format && npm run lint:fix && npm run typecheck && npm test",
    "db:generate": "npx nuxt db generate",
    "db:migrate": "npx nuxt db migrate",
    "db:seed": "npx tsx scripts/seed.ts",
    "db:reset": "rm -f .data/db/sqlite.db && npm run db:migrate && npm run db:seed",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@iconify-json/uil": "^1.2.3",
    "@libsql/client": "^0.15.15",
    "@lttr/puleo": "^0.8.1",
    "@nuxthub/core": "^0.10.1",
    "@zod/core": "^0.11.6",
    "better-auth": "^1.4.7",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "nuxt": "^4.2.2",
    "vue": "latest",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@lttr/nuxt-config-eslint": "latest",
    "@lttr/nuxt-puleo": "^0.0.8",
    "@nuxt/eslint": "^1.12.1",
    "@nuxt/fonts": "^0.12.1",
    "@nuxt/icon": "^2.1.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/test-utils": "^3.21.0",
    "@nuxtjs/plausible": "^2.0.1",
    "@nuxtjs/seo": "^3.2.2",
    "@total-typescript/ts-reset": "^0.6.1",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/nuxt": "^14.1.0",
    "drizzle-kit": "^0.31.8",
    "drizzle-seed": "^0.3.1",
    "eslint": "^9.39.1",
    "eslint-plugin-import-x": "^4.16.1",
    "happy-dom": "^20.0.11",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15",
    "vue-tsc": "^3.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher",
      "unrs-resolver"
    ]
  }
}
