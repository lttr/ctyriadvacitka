# =============================================================================
# Čtyřiadvacítka — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# Database
# SQLite database file path (used by NuxtHub/LibSQL)
# DATABASE_URL=file:./data/sqlite.db

# Authentication
# Secret key for session signing — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Email (SMTP)
# Used for sending contact form submissions
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Analytics (Plausible)
# Self-hosted Plausible instance
NUXT_PUBLIC_PLAUSIBLE_DOMAIN=ctyriadvacitka.skauting.cz
NUXT_PUBLIC_PLAUSIBLE_API_HOST=https://plausible.lttr.cz

# Site URL
NUXT_PUBLIC_SITE_URL=https://ctyriadvacitka.skauting.cz
